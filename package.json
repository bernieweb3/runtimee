{
  "name": "runtimee",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter @runtimee/core test",
    "test:evm": "pnpm --filter @runtimee/evm test",
    "test:sdk": "pnpm --filter @runtimee/sdk test",
    "typecheck": "pnpm -r typecheck",
    "boundaries": "depcruise packages --config .dependency-cruiser.cjs",
    "boundaries:graph": "depcruise packages --config .dependency-cruiser.cjs --output-type dot | dot -T svg > docs/dependency-graph.svg",
    "ci": "pnpm typecheck && pnpm boundaries && pnpm test"
  },
  "devDependencies": {
    "dependency-cruiser": "^17.4.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
